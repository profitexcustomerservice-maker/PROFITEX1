# Example environment variables for local development
# Do NOT commit real secrets. Replace placeholders locally only.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=profitexcustomerservice@gmail.com
# Set your Gmail App Password here locally (DO NOT commit)
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL="NovaProfit Support <profitexcustomerservice@gmail.com>"

# Optional: override in production with secure env vars or secret manager

# Production configuration hints
# Do not commit real production secrets.
DJANGO_SECRET_KEY=your-production-secret
DEBUG=False
ALLOWED_HOSTS=yourdomain.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com